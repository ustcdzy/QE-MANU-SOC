+!
+!----------------------------------------------------------------------------
+SUBROUTINE scale_soc_pp( ntyp, soc_scale )
+  !----------------------------------------------------------------------------
+  !! Scale the spin-orbit splitting at the pseudopotential channel level
+  !! without reducing the number of j=l+-1/2 channels.
+  !
+  USE kinds,            ONLY : DP
+  USE atom,             ONLY : rgrid
+  USE uspp_param,       ONLY : upf
+  !
+  IMPLICIT NONE
+  !
+  INTEGER, INTENT(IN) :: ntyp
+  REAL(DP), INTENT(IN) :: soc_scale
+  !
+  INTEGER :: nt, nbe, ind, ind1, l, mesh
+  REAL(DP) :: vionl, dplus, dminus
+  REAL(DP), ALLOCATABLE :: beta_avg(:), chi_avg(:)
+  !
+  IF ( ABS( soc_scale - 1.0_DP ) < 1.0D-12 ) RETURN
+  !
+  DO nt = 1, ntyp
+     IF ( .NOT. upf(nt)%has_so ) CYCLE
+     IF ( upf(nt)%tvanp ) CALL errore( 'scale_soc_pp', &
+          'soc_scale for FR ultrasoft/PAW pseudopotentials not implemented', 1 )
+     !
+     mesh = rgrid(nt)%mesh
+     ALLOCATE( beta_avg(mesh), chi_avg(mesh) )
+     !
+     nbe = 1
+     DO WHILE ( nbe <= upf(nt)%nbeta )
+        l = upf(nt)%lll(nbe)
+        IF ( l == 0 ) THEN
+           nbe = nbe + 1
+           CYCLE
+        END IF
+        IF ( nbe + 1 > upf(nt)%nbeta ) CALL errore( 'scale_soc_pp', 'wrong beta functions', 1 )
+        !
+        IF ( ABS( upf(nt)%jjj(nbe) - upf(nt)%lll(nbe) + 0.5D0 ) < 1.D-7 ) THEN
+           IF ( ABS( upf(nt)%jjj(nbe+1) - upf(nt)%lll(nbe+1) - 0.5D0 ) > 1.D-7 ) &
+                CALL errore( 'scale_soc_pp', 'wrong beta functions', 2 )
+           ind  = nbe + 1
+           ind1 = nbe
+        ELSE
+           IF ( ABS( upf(nt)%jjj(nbe+1) - upf(nt)%lll(nbe+1) + 0.5D0 ) > 1.D-7 ) &
+                CALL errore( 'scale_soc_pp', 'wrong beta functions', 3 )
+           ind  = nbe
+           ind1 = nbe + 1
+        END IF
+        !
+        dplus  = upf(nt)%dion(ind,ind)
+        dminus = upf(nt)%dion(ind1,ind1)
+        vionl = ( ( l + 1.D0 ) * dplus + l * dminus ) / ( 2.D0 * l + 1.D0 )
+        beta_avg(1:mesh) = 1.D0 / ( 2.D0 * l + 1.D0 ) * &
+             ( ( l + 1.D0 ) * SQRT( dplus / vionl ) * upf(nt)%beta(1:mesh,ind) + &
+               l * SQRT( dminus / vionl ) * upf(nt)%beta(1:mesh,ind1) )
+        !
+        upf(nt)%beta(1:mesh,ind) = beta_avg(1:mesh) + &
+             soc_scale * ( upf(nt)%beta(1:mesh,ind) - beta_avg(1:mesh) )
+        upf(nt)%beta(1:mesh,ind1) = beta_avg(1:mesh) + &
+             soc_scale * ( upf(nt)%beta(1:mesh,ind1) - beta_avg(1:mesh) )
+        upf(nt)%dion(ind,ind) = vionl + soc_scale * ( dplus - vionl )
+        upf(nt)%dion(ind1,ind1) = vionl + soc_scale * ( dminus - vionl )
+        !
+        nbe = nbe + 2
+     END DO
+     !
+     nbe = 1
+     DO WHILE ( nbe <= upf(nt)%nwfc )
+        l = upf(nt)%lchi(nbe)
+        IF ( l == 0 ) THEN
+           nbe = nbe + 1
+           CYCLE
+        END IF
+        IF ( nbe + 1 > upf(nt)%nwfc ) CALL errore( 'scale_soc_pp', 'wrong chi functions', 1 )
+        !
+        IF ( ABS( upf(nt)%jchi(nbe) - upf(nt)%lchi(nbe) + 0.5D0 ) < 1.D-7 ) THEN
+           IF ( ABS( upf(nt)%jchi(nbe+1) - upf(nt)%lchi(nbe+1) - 0.5D0 ) > 1.D-7 ) &
+                CALL errore( 'scale_soc_pp', 'wrong chi functions', 2 )
+           ind  = nbe + 1
+           ind1 = nbe
+        ELSE
+           IF ( ABS( upf(nt)%jchi(nbe+1) - upf(nt)%lchi(nbe+1) + 0.5D0 ) > 1.D-7 ) &
+                CALL errore( 'scale_soc_pp', 'wrong chi functions', 3 )
+           ind  = nbe
+           ind1 = nbe + 1
+        END IF
+        !
+        chi_avg(1:mesh) = ( ( l + 1.D0 ) * upf(nt)%chi(1:mesh,ind) + &
+                            l * upf(nt)%chi(1:mesh,ind1) ) / ( 2.D0 * l + 1.D0 )
+        upf(nt)%chi(1:mesh,ind) = chi_avg(1:mesh) + &
+             soc_scale * ( upf(nt)%chi(1:mesh,ind) - chi_avg(1:mesh) )
+        upf(nt)%chi(1:mesh,ind1) = chi_avg(1:mesh) + &
+             soc_scale * ( upf(nt)%chi(1:mesh,ind1) - chi_avg(1:mesh) )
+        !
+        nbe = nbe + 2
+     END DO
+     !
+     DEALLOCATE( beta_avg, chi_avg )
+  END DO
+  !
+END SUBROUTINE scale_soc_pp
